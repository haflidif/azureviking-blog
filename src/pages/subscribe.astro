---
import Layout from '@/layouts/Layout.astro';
import { SITE } from '@/config';
import Breadcrumbs from '@/components/Breadcrumbs.svelte';
import { getBreadcrumbSchema } from '@/lib/schemas';
import SubscribeForm from '@/components/SubscribeForm.astro';

const schema = getBreadcrumbSchema([
  { name: 'Subscribe', url: new URL('/subscribe', Astro.site).toString() },
]);
---

<Layout
  title={`Subscribe | ${SITE.title}`}
  description="Subscribe to AzureViking's newsletter for the latest posts on Cloud Security, Azure, and Infrastructure as Code."
  schemas={[schema]}
>
  <main class="mx-auto w-full max-w-3xl px-4 pb-12">
    <Breadcrumbs items={[{ label: 'Subscribe', href: '/subscribe' }]} client:load />

    <div class="mt-8">
      <SubscribeForm
        heading="Stay in the Loop"
        description="Get notified when I publish new articles about Cloud Security, Azure, Infrastructure as Code, and more. No spam, unsubscribe anytime."
      />
    </div>

    <div class="mt-10 p-6 rounded-xl border border-border bg-card text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 text-[#f26522]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
        <h3 class="text-base font-bold">Subscribe via RSS</h3>
      </div>
      <p class="text-sm text-muted-foreground mb-4">
        Prefer RSS? Add the feed to your favorite reader and never miss a post.
      </p>
      <a
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-background text-sm font-medium hover:bg-accent hover:text-primary transition-all no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
        {SITE.website}/rss.xml
      </a>
    </div>
  </main>
</Layout>
